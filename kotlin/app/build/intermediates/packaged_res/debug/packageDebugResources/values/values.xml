<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="amarillo_pastel">#FFD97D</color>
    <color name="black">#000000</color>
    <color name="rojo_pastel">#EF9A9A</color>
    <color name="text_secondary">#6C757D</color>
    <color name="uat_azul">#8AB4D7</color>
    <color name="uat_azul_claro">#D6E8F5</color>
    <color name="uat_azul_hover">#6FA3CC</color>
    <color name="uat_blanco">#FFFFFF</color>
    <color name="uat_gris">#B8BCC2</color>
    <color name="uat_gris_claro">#F5F6F8</color>
    <color name="uat_naranja">#FFB39C</color>
    <color name="uat_naranja_claro">#FFE5DD</color>
    <color name="uat_naranja_hover">#FF9F85</color>
    <color name="uat_negro">#3D4450</color>
    <color name="verde_pastel">#81C784</color>
    <color name="white">#FFFFFF</color>
    <dimen name="icon_size_large">60dp</dimen>
    <dimen name="icon_size_medium">40dp</dimen>
    <dimen name="icon_size_small">24dp</dimen>
    <dimen name="icon_size_xlarge">100dp</dimen>
    <dimen name="icon_size_xxlarge">120dp</dimen>
    <dimen name="radius_large">50dp</dimen>
    <dimen name="radius_medium">12dp</dimen>
    <dimen name="radius_small">8dp</dimen>
    <dimen name="spacing_large">24dp</dimen>
    <dimen name="spacing_medium">16dp</dimen>
    <dimen name="spacing_small">8dp</dimen>
    <dimen name="spacing_xlarge">32dp</dimen>
    <dimen name="text_size_large">18sp</dimen>
    <dimen name="text_size_medium">16sp</dimen>
    <dimen name="text_size_normal">14sp</dimen>
    <dimen name="text_size_small">12sp</dimen>
    <dimen name="text_size_xlarge">24sp</dimen>
    <dimen name="text_size_xxlarge">32sp</dimen>
    <string name="app_name">DevCore</string>
    <style name="DevCoreButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">8dp</item>
        <item name="android:paddingTop">15dp</item>
        <item name="android:paddingBottom">15dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:elevation">0dp</item>
    </style>
    <style name="DevCoreButton.Danger">
        <item name="backgroundTint">@color/rojo_pastel</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="DevCoreButton.Outline">
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="android:textColor">@color/uat_azul</item>
        <item name="strokeColor">@color/uat_azul</item>
        <item name="strokeWidth">2dp</item>
    </style>
    <style name="DevCoreButton.Primary">
        <item name="backgroundTint">@color/uat_naranja</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="DevCoreButton.Secondary">
        <item name="backgroundTint">@color/uat_azul</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="DevCoreButton.Success">
        <item name="backgroundTint">@color/verde_pastel</item>
        <item name="android:textColor">@color/white</item>
    </style>
    <style name="DevCoreCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/white</item>
    </style>
    <style name="DevCoreTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/uat_naranja</item>
        <item name="hintTextColor">@color/uat_azul</item>
        <item name="android:textColorHint">@color/uat_azul</item>
    </style>
    <style name="NoTransitionAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@null</item>
        <item name="android:activityOpenExitAnimation">@null</item>
        <item name="android:activityCloseEnterAnimation">@null</item>
        <item name="android:activityCloseExitAnimation">@null</item>
    </style>
    <style name="Theme.DevCore" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/uat_naranja</item>
        <item name="colorPrimaryVariant">@color/uat_naranja_hover</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/uat_azul</item>
        <item name="colorSecondaryVariant">@color/uat_azul_hover</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/uat_gris_claro</item>
        
        <item name="android:windowAnimationStyle">@style/NoTransitionAnimation</item>
    </style>
</resources>